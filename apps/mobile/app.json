{
  "expo": {
    "name": "MindSHED",
    "slug": "mindshed",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mindshed",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.mindshed.app"
    },
    "android": {
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#FFF9DA",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.mindshed.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF9DA",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#315B45",
          "defaultChannel": "gentle-reminders"
        }
      ],
      "expo-secure-store",
      [
        "expo-sqlite",
        {
          "useSQLCipher": true,
          "enableFTS": false
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "MindSHED reads your daily sleep duration and step totals to add optional context to the wellbeing insights shown only on this device.",
          "NSHealthUpdateUsageDescription": "MindSHED does not write health data.",
          "background": false
        }
      ],
      "expo-health-connect",
      "./plugins/with-health-connect-main-activity",
      "./plugins/with-android-private-data",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
