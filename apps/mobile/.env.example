# Copy to .env. When testing on a physical phone, replace localhost with your
# Mac's LAN IP (shown in the Expo start output), e.g. http://192.168.1.20:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
# Optional development-only helper. Never configure this in preview/production.
# EXPO_PUBLIC_LOCAL_PILOT_CODE=replace-with-a-local-batch-code
# Set only after the controller, contacts, retention wording and final versions
# have written approval. Production consent is blocked while this is false.
EXPO_PUBLIC_LEGAL_DOCUMENTS_APPROVED=false
# Optional contact consent remains hidden unless separately approved.
EXPO_PUBLIC_ENABLE_MARKETING_CONSENT=false
EXPO_PUBLIC_ENABLE_SWEMWBS=true
# Keep research upload off until the approved consent/data dictionary and
# Warwick digital presentation review explicitly cover SWEMWBS.
EXPO_PUBLIC_ENABLE_SWEMWBS_UPLOADS=false
# Warwick must review the participant-facing feedback before enabling scores.
EXPO_PUBLIC_ENABLE_SWEMWBS_FEEDBACK=false
