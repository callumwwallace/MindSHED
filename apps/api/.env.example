# Copy to .env and fill in. Pilot endpoints fail closed when these are missing.
DATABASE_URL=postgres://localhost:5432/mindshed
PORT=3000
PILOT_ACCESS_CODE=replace-with-a-long-random-batch-code-at-least-12-characters
PILOT_CODE_HASH_KEY=replace-with-a-separate-32-byte-secret-from-your-secret-manager
PILOT_STUDY_CODE=mindshed-pilot-2026
PILOT_CODE_VALID_FROM=2026-09-01
PILOT_CODE_EXPIRES_ON=2026-12-31
PILOT_CODE_CAPACITY=100
PILOT_ENROLMENT_ENABLED=false
PILOT_UPLOADS_ENABLED=false
PILOT_SWEMWBS_UPLOADS_ENABLED=false
PILOT_LIFECYCLE_EXECUTE=false
# Set only after the controller approves each retention period.
# PILOT_ABANDONED_ENROLMENT_DAYS=30
# PILOT_WITHDRAWN_DATA_DAYS=30
# PILOT_PARTICIPANT_RETENTION_DAYS=365
# PILOT_LIFECYCLE_STUDY_CODE=approved-study-code
PILOT_MINIMUM_APP_VERSION=1.0.0
# Comma-separated HTTPS origins for the secondary web client. Native apps do not use CORS.
CORS_ORIGIN=https://app.example.com
