# Copy to .env and fill in. Pilot endpoints fail closed when these are missing.
DATABASE_URL=postgres://localhost:5432/mindshed
# Production must use require or verify-full. Prefer verify-full with the
# provider CA configured in the runtime trust store.
DATABASE_SSL_MODE=disable
PORT=3000
PILOT_ACCESS_CODE=replace-with-a-long-random-batch-code-at-least-12-characters
PILOT_CODE_HASH_KEY=replace-with-a-base64url-or-hex-encoding-of-32-random-bytes
PILOT_STUDY_CODE=mindshed-pilot-2026
PILOT_CODE_VALID_FROM=2026-09-01
PILOT_CODE_EXPIRES_ON=2026-12-31
PILOT_CODE_CAPACITY=100
PILOT_ENROLMENT_ENABLED=false
PILOT_UPLOADS_ENABLED=false
PILOT_SWEMWBS_UPLOADS_ENABLED=false
# The API independently enforces this approval. Do not enable it merely because
# a mobile build has its corresponding public flag set.
PILOT_LEGAL_DOCUMENTS_APPROVED=false
PILOT_MARKETING_CONSENT_ENABLED=false
PILOT_MINIMUM_APP_VERSION=1.0.0
PILOT_MAX_EVENTS_PER_PARTICIPANT=500
PILOT_MAX_CONSENTS_PER_PARTICIPANT=50
RATE_LIMIT_MAX=120
# Set true only when every route to the API passes through a trusted proxy that
# overwrites forwarded client-address headers.
TRUST_PROXY=false
PILOT_LIFECYCLE_EXECUTE=false
# Set only after the controller approves each retention period.
# PILOT_ABANDONED_ENROLMENT_DAYS=30
# PILOT_WITHDRAWN_DATA_DAYS=30
# PILOT_PARTICIPANT_RETENTION_DAYS=365
# PILOT_LIFECYCLE_STUDY_CODE=approved-study-code
# Comma-separated HTTPS origins for an explicitly approved browser client.
# The pilot app is native-only, so omit this unless another reviewed client exists.
# CORS_ORIGIN=https://approved-client.example.com
