{
  "name": "@mindshed/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node --enable-source-maps dist/index.cjs",
    "test": "tsx --test src/*.unit.test.ts src/pilot-contract.test.ts",
    "test:integration": "tsx --test src/pilot-flow.integration.test.ts",
    "test:http": "tsx --test src/pilot-http.integration.test.ts",
    "test:lifecycle": "tsx --test src/data-lifecycle.integration.test.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed:pilot": "tsx src/scripts/seed-pilot-code.ts",
    "db:lifecycle": "tsx src/scripts/run-data-lifecycle.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@mindshed/shared": "*",
    "@trpc/server": "^11.17.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "postgres": "^3.4.9",
    "superjson": "^2.2.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@trpc/client": "^11.17.0",
    "@types/node": "^25.9.3",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2"
  }
}
