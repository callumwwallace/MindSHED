{
  "name": "mindshed",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "npm run dev --workspace @mindshed/api",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "mobile": "npm run start --workspace mobile",
    "mobile:tunnel": "npm run start:tunnel --workspace mobile",
    "postinstall": "patch-package",
    "sim": "npm run sim --workspace mobile",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "verify": "npm run typecheck && npm run lint --workspace mobile && npm run test --workspace mobile && npm run test --workspace @mindshed/api"
  },
  "engines": {
    "node": ">=22.18 <23"
  },
  "overrides": {
    "fast-uri": "3.1.4",
    "minimatch@>=10": {
      "brace-expansion": "5.0.7"
    },
    "react-devtools-core": {
      "shell-quote": "1.10.0"
    }
  },
  "devDependencies": {
    "patch-package": "^8.0.1"
  }
}
