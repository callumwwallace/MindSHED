{
  "name": "mindshed",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api": "npm run dev --workspace @mindshed/api",
    "mobile": "npm run start --workspace mobile",
    "mobile:tunnel": "npm run start:tunnel --workspace mobile",
    "sim": "npm run sim --workspace mobile",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  }
}
